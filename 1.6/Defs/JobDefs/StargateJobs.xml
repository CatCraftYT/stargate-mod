<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<JobDef>
		<defName>StargatesMod_EnterStargate</defName>
		<driverClass>StargatesMod.JobDriver_EnterStargate</driverClass>
		<reportString>entering TargetA.</reportString>
		<allowOpportunisticPrefix>true</allowOpportunisticPrefix>
	</JobDef>
	
	<JobDef>
		<defName>StargatesMod_DialStargate</defName>
		<driverClass>StargatesMod.JobDriver_DialStargate</driverClass>
		<reportString>using TargetA.</reportString>
		<allowOpportunisticPrefix>true</allowOpportunisticPrefix>
	</JobDef>
	
	<JobDef>
		<defName>StargatesMod_BringToStargate</defName>
		<driverClass>StargatesMod.JobDriver_BringToStargate</driverClass>
		<reportString>bringing TargetA to TargetB.</reportString>
		<allowOpportunisticPrefix>true</allowOpportunisticPrefix>
	</JobDef>
	
	<JobDef>
		<defName>StargatesMod_InstallIris</defName>
		<driverClass>StargatesMod.JobDriver_InstallIris</driverClass>
		<reportString>installing iris on TargetB.</reportString>
		<allowOpportunisticPrefix>true</allowOpportunisticPrefix>
	</JobDef>
	
	<JobDef>
		<defName>StargatesMod_DecodeGlyphs</defName>
		<driverClass>StargatesMod.JobDriver_DecodeGlyphs</driverClass>
		<reportString>decoding stargate glyphs.</reportString>
		<allowOpportunisticPrefix>true</allowOpportunisticPrefix>
	</JobDef>
	
	<JobDef>
		<defName>StargatesMod_WatchStargate</defName>
		<driverClass>StargatesMod.JobDriver_WatchStargate</driverClass>
		<reportString>watching stargate open.</reportString>
		<isIdle>true</isIdle>
		<suspendable>false</suspendable>
		<allowOpportunisticPrefix>true</allowOpportunisticPrefix>
		<carryThingAfterJob>true</carryThingAfterJob>
		<dropThingBeforeJob>false</dropThingBeforeJob>
	</JobDef>
 
</Defs>